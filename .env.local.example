# HenloFaucet contract address on Berachain mainnet
# Default: 0x701A9A14F7f4a79225059D4AE88A6F16794C212d — change only if using a fork
NEXT_PUBLIC_FAUCET_ADDRESS=0x701A9A14F7f4a79225059D4AE88A6F16794C212d

# WalletConnect Cloud project ID — required for wallet modal
# Get one at https://cloud.walletconnect.com (free tier works)
# For local dev only, "demo" is accepted but rate-limited
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Berachain mainnet RPC URL (optional)
# Defaults to https://rpc.berachain.com/ if not set
# Use a dedicated endpoint (Alchemy, Infura, QuickNode) for production
NEXT_PUBLIC_RPC_URL=https://rpc.berachain.com/
